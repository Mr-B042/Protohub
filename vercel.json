{
  "rewrites": [
    {
      "source": "/org-manifest.webmanifest",
      "destination": "https://protohub-production.up.railway.app/api/public/pwa/manifest"
    },
    {
      "source": "/org-icons/:path*",
      "destination": "https://protohub-production.up.railway.app/api/public/pwa/icons/:path*"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
