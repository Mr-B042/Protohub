{
  "name": "protohub-style-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:local": "npm run guard:live-ui && vite --host 127.0.0.1 --port 5174",
    "backend:dev:local": "npm --prefix backend run dev:local",
    "local:sandbox:check": "node scripts/local-sandbox-check.mjs",
    "guard:live-ui": "node scripts/live-ux-guard.mjs",
    "build": "npm run guard:live-ui && tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "mobile:brand": "bash scripts/refresh-mobile-branding.sh",
    "mobile:push:doctor": "node scripts/mobile-push-doctor.mjs",
    "lint:hooks": "eslint src/App.tsx src/pages/PublicOrderFormPage.tsx",
    "mock:products": "node mock-api/products-server.mjs",
    "test:products:curl": "bash scripts/test-product-api.sh",
    "test:public-form:smoke": "playwright test tests/public-form.smoke.spec.ts",
    "release:public-form": "npm run lint:hooks && npm run build && npm --prefix backend run build && npm run test:public-form:smoke"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/react": "^10.51.0",
    "@supabase/supabase-js": "^2.105.3",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19"
  }
}
