# ── Supabase ──────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── JWT ───────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-secret

# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend ──────────────────────────────────────────────
# Primary frontend URL used for reset links and branded app links.
FRONTEND_URL=http://localhost:5173
# Optional extra allowed frontend origins for authenticated API CORS.
# Comma-separated, e.g. https://protohub-zeta.vercel.app,https://brightpathhubs.com
FRONTEND_URLS=

# ── Public API URL ────────────────────────────────────────
# Optional explicit backend base URL used for push-branding assets.
# In Railway production we also auto-fallback to RAILWAY_PUBLIC_DOMAIN.
PUBLIC_API_URL=http://localhost:4000

# ── Email (optional env fallbacks) ────────────────────────
# ProtoHub stores per-org email settings in the database. These env vars act
# as safe fallbacks for the sender identity and provider secrets when a field
# is left blank in the org settings UI.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM_NAME=Protohub
EMAIL_FROM_EMAIL=
EMAIL_REPLY_TO=
MAILJET_API_PUBLIC=
MAILJET_API_PRIVATE=

# ── SMS (optional env fallbacks) ──────────────────────────
# ProtoHub stores per-org SMS settings in the database. These env vars can act
# as safe fallbacks for the Multitexter key and sender name.
MULTITEXTER_API_KEY=
SMS_SENDER_NAME=Protohub

# ── WhatsApp / Baileys runtime ────────────────────────────
# For production, point this to a durable filesystem path.
# Example on Railway with a mounted volume: /data/whatsapp
WHATSAPP_SESSION_DIR=

# ── Web Push (VAPID) ──────────────────────────────────────
# Generate keys locally with:  npx web-push generate-vapid-keys
# Then add the printed values here. VAPID_EMAIL must be a mailto: URL.
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_EMAIL=mailto:you@example.com

# ── Native Push (Firebase / FCM) ──────────────────────────
# Either provide the full Firebase service account JSON in one env var,
# or split the key parts across the 3 vars below.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep literal \n characters when storing in env managers that require one-line values.
FIREBASE_PRIVATE_KEY=
