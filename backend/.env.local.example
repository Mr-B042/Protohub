# Copy this file to backend/.env.local for localhost only.
# Use a separate Supabase project created for testing, then seed it with mock data.

# ── Local sandbox safety ──────────────────────────────────
LOCAL_DATA_MODE=test-supabase
LOCAL_DATABASE_IS_MOCK=true
# Optional but recommended: paste the live production Supabase URL here.
# If SUPABASE_URL ever matches it, localhost will refuse to start.
PRODUCTION_SUPABASE_URL=
ALLOW_PROD_DB_LOCAL=false

# ── Test Supabase project ─────────────────────────────────
SUPABASE_URL=https://your-test-project-id.supabase.co
SUPABASE_ANON_KEY=your-test-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-test-service-role-key

# ── Local server ──────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-local-secret
FRONTEND_URL=http://127.0.0.1:5174
FRONTEND_URLS=http://localhost:5174,http://127.0.0.1:5174
PUBLIC_API_URL=http://localhost:4000

# ── Local side-effect safety ──────────────────────────────
ENABLE_BACKGROUND_JOBS=0
ENABLE_WHATSAPP_RUNTIME=0
WHATSAPP_SESSION_DIR=.local/whatsapp-sessions

# Optional local-only fallback providers. Keep blank unless testing them.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM_NAME=Protohub Local
EMAIL_FROM_EMAIL=
EMAIL_REPLY_TO=
MAILJET_API_PUBLIC=
MAILJET_API_PRIVATE=
MULTITEXTER_API_KEY=
SMS_SENDER_NAME=Protohub
VAPID_PUBLIC_KEY=your-local-vapid-public-key
VAPID_PRIVATE_KEY=your-local-vapid-private-key
VAPID_EMAIL=mailto:local@example.test
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
