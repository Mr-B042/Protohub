{
  "name": "protohub-api",
  "version": "1.0.0",
  "description": "ProtoHub CRM — Node.js + Supabase backend",
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed-agents": "tsx src/scripts/seed-agents.ts",
    "db:seed-orders": "tsx src/scripts/seed-orders.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "node-mailjet": "^6.0.11",
    "resend": "^6.12.2",
    "tsx": "^4.19.2",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "typescript": "^5.7.2"
  }
}
