# Protohub Northflank backup environment
# Copy your production backend values here, then keep the passive backup flag
# disabled unless you are actively promoting Northflank during an outage.

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=

# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Frontend / CORS ───────────────────────────────────────
FRONTEND_URL=https://protohub-zeta.vercel.app
FRONTEND_URLS=https://brightpathhubs.com,https://www.brightpathhubs.com

# ── Public API URL ────────────────────────────────────────
PUBLIC_API_URL=https://<your-northflank-domain>

# ── Email ─────────────────────────────────────────────────
EMAIL_PROVIDER=
RESEND_API_KEY=
EMAIL_FROM_NAME=
EMAIL_FROM_EMAIL=
EMAIL_REPLY_TO=
MAILJET_API_PUBLIC=
MAILJET_API_PRIVATE=

# ── SMS ───────────────────────────────────────────────────
MULTITEXTER_API_KEY=
SMS_SENDER_NAME=

# ── Web Push (VAPID) ──────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# ── Native Push (Firebase / FCM) ──────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Passive backup safety switch ──────────────────────────
ENABLE_BACKGROUND_JOBS=false
