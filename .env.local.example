# Copy this file to .env.local for localhost.
# Keep the UI code identical to production; only point data/API env at local/test services.

VITE_API_URL=http://localhost:4000

# Optional realtime/public Supabase config. If set, use the same test Supabase
# project as backend/.env.local, never the production project.
VITE_SUPABASE_URL=https://your-test-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-test-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-test-anon-key
